<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_parte_tree" model="ir.ui.view">
        <field name="name">gestion_faltas.parte.tree</field>
        <field name="model">gestion_faltas.parte</field>
        <field name="arch" type="xml">
            <tree>
                <field name="name"/>
                <field name="grupo_id"/>
                <field name="profesor_id"/>
                <field name="alumno_id"/>
                <field name="estado" widget="badge"
                    decoration-warning="estado== 'pendiente_contactar_padres'"
                    decoration-success="estado== 'contactado_padres'"
                    decoration-danger="estado== 'cerrado'"/>
            </tree>
        </field>
    </record>


    <record id="view_parte_form" model="ir.ui.view">
        <field name="name">gestion_faltas.partes.form</field>
        <field name="model">gestion_faltas.parte</field>
        <field name="arch" type="xml">
            <form create="false">
                <header>
                    <button groups="gestion_faltas.group_partes_direccion" name="action_cerrar_parte" string="Cerrar Parte" type="object" class="btn-danger" attrs="{'invisible': [('estado', '!=', 'contactado_padres')]}"/>
                    <button groups="gestion_faltas.group_partes_direccion" name="action_reabrir_parte" string="Reabrir" type="object" class="btn-primary" attrs="{'invisible': [('estado', '!=', 'cerrado')]}"/>
                </header>

                <sheet>
                    <field name="estado" invisible="1" force_save="1" readonly="1"/>
                    <widget name="web_ribbon"
                        title="Pendiente de contactar"
                        bg_color="bg-warning"
                        attrs="{'invisible': [('estado', '!=', 'pendiente_contactar_padres')]}"/>

                    <widget name="web_ribbon"
                        title="Contactado"
                        bg_color="bg-success"
                        attrs="{'invisible': [('estado', '!=', 'contactado_padres')]}"/>

                    <widget name="web_ribbon"
                        title="Cerrado"
                        bg_color="bg-danger"
                        attrs="{'invisible': [('estado', '!=', 'cerrado')]}"/>


                    <group>

                        <group>
                            <field name="name" invisible="1" readonly="1"/>
                            <field name="numero_Parte"  readonly="1"/>        
                            <field name="grupo_id"  placeholder="Elije grupo del alumno" attrs="{'readonly': [('estado', '=', 'cerrado')]}" options="{'no_open': True, 'no_create_edit': True}"/>
                            <field name="alumno_id" placeholder="Elije grupo antes que el alumno"
                            attrs="{'readonly': ['|', ('grupo_id', '=', False), ('estado', '=', 'cerrado')],'required': [('grupo_id', '!=', False)]}"
                            options="{'no_open': True, 'no_create_edit': True}"
                            domain="[('grupo_id', '=', grupo_id)]"/>
                            <field name="profesor_id" placeholder="Escribe o selecciona para buscar nombre Profesor" attrs="{'readonly': [('estado', '=', 'cerrado')]}" options="{'no_open': True, 'no_create_edit': True}"/>
                        </group>

                        <group>
                            <field name="asignatura_id"  placeholder="Busca o selecciona asignatura" attrs="{'readonly': [('estado', '=', 'cerrado')]}" options="{'no_open': True, 'no_create_edit': True}"/>
                            <field name="fecha_hora" attrs="{'readonly': [('estado', '=', 'cerrado')]}" options="{'no_open': True, 'no_create_edit': True}"/>
                            <field name="lugar"  placeholder="Selecciona el lugar de los hechos" attrs="{'readonly': [('estado', '=', 'cerrado')]}" options="{'no_open': True, 'no_create_edit': True}"/>
                            <field name="motivo_id"  placeholder="Selecciona el motivo" attrs="{'readonly': [('estado', '=', 'cerrado')]}" options="{'no_open': True, 'no_create_edit': True}"/>
                        </group>
                    </group>


                    <group string="Descripción de los hechos y acciones tomadas por parte del profesor">
                        <field name="descripcion" placeholder="Describe lo ocurrido..." attrs="{'readonly': [('estado', '=', 'cerrado')]}"/>
                        <field name="acciones_inmediatas" placeholder="Acciones tomadas en el momento..." attrs="{'readonly': [('estado', '=', 'cerrado')]}"/>
                    </group>


                    <group string="Llamadas a los padres" style="margin-top:20px;"  groups="gestion_faltas.group_partes_direccion">
                        
                            
                            <field name="llamada1"
                                placeholder="Llamada1"
                                force_save="1"
                                attrs="{'readonly': ['|', ('llamada1', '!=', False), ('estado', '=', 'cerrado')]}"/>
                            <field name="llamada1_fecha" force_save="1" readonly="1"/>
                           
                            <field name="llamada2"
                                placeholder="Llamada2"
                                force_save="1"
                                attrs="{'invisible': [('llamada1', '!=', 'no_contesta')], 'readonly':  ['|', ('llamada2', '!=', False), ('estado', '=', 'cerrado')]}"/>
                            <field name="llamada2_fecha" force_save="1" readonly="1"  attrs="{'invisible': [('llamada1', '!=', 'no_contesta')]}"/>
                            
                            <field name="llamada3"
                                placeholder="Llamada3"
                                force_save="1"
                                attrs="{'invisible': ['|', ('llamada1', '!=', 'no_contesta'), ('llamada2', '!=', 'no_contesta')],'readonly':[ '|', ('llamada3', '=', 'contesta'),('estado', '=', 'cerrado')]}"/>
                            <field name="llamada3_fecha" force_save="1" readonly="1"  attrs="{'invisible': ['|', ('llamada1', '!=', 'no_contesta'), ('llamada2', '!=', 'no_contesta')]}"/>
                        
                    </group>


                    <group string="Observaciones del caso tras llamada con los padres del menor"  groups="gestion_faltas.group_partes_direccion">
                        <field name="observaciones" placeholder="Observaciones adicionales..."  attrs="{'readonly': [('estado','=','cerrado')]}"/>
                    </group>

                    <label for="fecha_Creacion_parte"/>
                    <div style="color:red;">
                        <field name="fecha_Creacion_parte"  readonly="1"/>
                    </div>    
                    
                </sheet>

            </form>
        </field>
    </record>

    <!--resto de vistas kamban, grafias, calendario etc.-->



    <!--vista busqueda-->

    <record id="view_parte_search" model="ir.ui.view">
        <field name="name">gestion_faltas.parte.search</field>
        <field name="model">gestion_faltas.parte</field>
        <field name="arch" type="xml">
            <search>

                <field name="alumno_id" string="Alumno"/>
                <field name="profesor_id" string="Profesor"/>
                <field name="grupo_id" string="Grupo"/>
                <field name="motivo_id" string="Motivo"/>
                <field name="etapa" string="Etapa"/>

                <filter string="Pendientes" name="pendiente" domain="[('estado','=','pendiente_contactar_padres')]"/>
                <filter string="Contactados" name="contactado"  domain="[('estado','=','contactado_padres')]"/>
                <filter string="Cerrados" name="cerrado" domain="[('estado','=','cerrado')]"/>

                <filter string="ESO" name="eso" domain="[('etapa','=','ESO')]"/>
                <filter string="FP Básica" name="fpb" domain="[('etapa','=','FPB')]"/>
                <filter string="Ciclos"  name="ciclos" domain="[('etapa','=','CICLOS')]"/>
                <filter string="Bachillerato" name="bach" domain="[('etapa','=','BACH')]"/>

            </search>
        </field>
    </record>

    

    <!--Vista kamban parte-->

    <record id="view_parte_kanban" model="ir.ui.view">
        <field name="name">gestion_faltas.parte.kanban</field>
        <field name="model">gestion_faltas.parte</field>
        <field name="arch" type="xml">
            <kanban colors="red: estado == 'cerrado'; orange: estado == 'pendiente_contactar_padres'; green: estado == 'contactado_padres'">

                <field name="estado" widget="kanban_color"/>

                <templates>
                    <t t-name="kanban-box">
                        <div t-attf-class="oe_kanban_global_click #{record.estado.raw_value == 'cerrado' ? 'oe_kanban_color_1' : (record.estado.raw_value == 'contactado_padres' ? 'oe_kanban_color_10' : 'oe_kanban_color_3')}">

                            <div class="oe_kanban_global_click">

                                <div class="oe_kanban_details">

                                    <strong class="o_kanban_record_title">
                                        <field name="name"/>
                                    </strong>

                                    <div>
                                        <strong>Estado:</strong>
                                        <field name="estado"/>
                                    </div>

                                    <div>
                                        <strong>Alumno:</strong>
                                        <field name="alumno_id"/>
                                    </div>

                                    <div>
                                        <strong>Grupo:</strong>
                                        <field name="grupo_id"/>
                                    </div>

                                    <div>
                                        <strong>Profesor:</strong>
                                        <field name="profesor_id"/>
                                    </div>

                                    <div>
                                        <strong>Motivo:</strong>
                                        <field name="motivo_id"/>
                                    </div>

                                    <div>
                                        <strong>Fecha incidente:</strong>
                                        <field name="fecha_hora"/>
                                    </div>

                                </div>

                            </div>

                        </div> 
                    </t>
                </templates>
            </kanban>
        </field>
    </record>





    <!--vista parte calendar-->

    <record id="view_parte_calendar" model="ir.ui.view">
        <field name="name">gestion_faltas.parte.calendar</field>
        <field name="model">gestion_faltas.parte</field>
        <field name="arch" type="xml">

            <calendar string="Calendario de Partes"
                    date_start="fecha_Creacion_parte"
                    color="estado"
                    quick_add="False"
                    mode="month"
                    event_open_popup="1">

                <field name="name"/>
                <field name="alumno_id"/>
                <field name="grupo_id"/>
                <field name="motivo_id"/>
                <field name="fecha_Creacion_parte"/>

            </calendar>

        </field>
    </record>


    <!--vista parte pivot-->


    <record id="view_parte_pivot" model="ir.ui.view">
        <field name="name">gestion_faltas.parte.pivot</field>
        <field name="model">gestion_faltas.parte</field>
        <field name="arch" type="xml">
            <pivot string="Vista Pivot de Partes" display_quantity="True" default_order="fecha_Creacion_parte">

                <field name="fecha_Creacion_parte" type="col" interval="month"/>
                <field name="etapa" type="row"/>
                <field name="grupo_id" type="row"/>
                <field name="alumno_id" type="row"/>

            </pivot>
        </field>
    </record>











</odoo>

