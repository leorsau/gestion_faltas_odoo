<?xml version="1.0" encoding="UTF-8" ?>
<odoo>
    <record id="action_report_alumno" model="ir.actions.report">
        <field name="name">Reporte alumno</field>
        <field name="model">gestion_faltas.alumno</field>
        <field name="report_type">qweb-pdf</field>
        <field name="report_name">gestion_faltas.report_alumno</field>
        <field name="report_file">gestion_faltas.report_alumno</field>
        <field name="print_report_name">('Reporte_alumno - %s' % (object.name))</field>
        <field name="binding_model_id" ref="model_gestion_faltas_alumno"/>
        <field name="binding_type">report</field>

    </record>

    <template id="report_alumno">
        <t t-call="web.html_container">
            <t t-foreach="docs" t-as="obj">
                <t t-call="web.external_layout">
                    <div class="page">
                        <h2 class="text-center">Reporte alumno</h2>

                        <div style="margin-top:20px;">
                            <p><strong>Nombre completo:</strong> <t t-esc="obj.nombre_completo"/></p>
                            <p><strong>NIA:</strong> <t t-esc="obj.nia"/></p>
                            <p><strong>Grupo:</strong> <t t-esc="obj.grupo_id.name"/></p>
                        </div>
                        <table class="table table-sm" style="width:100%; table-layout: fixed;">
                            <thead>
                                <tr style="color: white;">
                                    <th class="text-center" style="background-color: #446688; padding: 10px;">Nº Parte</th>
                                    <th class="text-center" style="background-color: #557799; padding: 10px;">Fecha creación</th>
                                    <th class="text-center" style="background-color: #446688; padding: 10px;">Fecha incidente</th>
                                    <th class="text-center" style="background-color: #557799; padding: 10px;">Motivo</th>
                                    <th class="text-center" style="background-color: #446688; padding: 10px;">Asignatura</th>
                                    <th class="text-center" style="background-color: #557799; padding: 10px;">Profesor</th>
                                </tr>
                            </thead>

                            <tbody>
                                <t t-foreach="obj.parte_ids" t-as="p">
                                    <tr>
                                        <td class="text-left"><t t-esc="p.numero_Parte"/></td>
                                        <td class="text-left"><t t-esc="p.fecha_Creacion_parte"/></td>
                                        <td class="text-left"><t t-esc="p.fecha_hora"/></td>
                                        <td class="text-left"><t t-esc="p.motivo_id.name"/></td>
                                        <td class="text-left"><t t-esc="p.asignatura_id.name"/></td>
                                        <td class="text-left"><t t-esc="p.profesor_id.name"/></td>
                                    </tr>
                                </t>
                            </tbody>
                        </table>
                    </div>
                </t>
            </t>
        </t>       

    </template>
</odoo>