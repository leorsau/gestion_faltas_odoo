<?xml version="1.0" encoding="utf-8"?>

<odoo>
    <record id="module_category_gestion_faltas" model="ir.module.category">
        <field name="name"> Gestión de faltas</field>
        <field name="sequence">1</field>
    </record>

    <record id="module_category_gestion_faltas_partes" model="ir.module.category">
        <field name="name"> Gestión de faltas/partes</field>
        <field name="sequence">1</field>
        <field name="parent_id" ref="module_category_gestion_faltas"/>
    </record>





    <record id="group_partes_profesor" model="res.groups">
        <field name="name">Profesor: Solo puede ver y operar sus partes</field>
        <field name="category_id" ref="module_category_gestion_faltas_partes"/>
    </record>

    <record id="group_partes_tutor" model="res.groups">
        <field name="name">Tutor: Puede ver partes de grupos</field>
        <field name="category_id" ref="module_category_gestion_faltas_partes"/>
        <field name="implied_ids" eval="[(4, ref('group_partes_profesor'))]"/>
    </record>

    <record id="group_partes_direccion" model="res.groups">
        <field name="name">Dirección: Puede ver informes y administrar el sistema</field>
        <field name="category_id" ref="module_category_gestion_faltas_partes"/>
        <field name="implied_ids" eval="[(4, ref('group_partes_tutor'))]"/>
    </record>




    <record id="gestion_faltas_parte_propios_rule" model="ir.rule">
        <field name="name">Gestión de partes propios</field>
        <field name="model_id" ref="model_gestion_faltas_parte"/>
        <field name="domain_force">[('create_uid', '=', user.id)]</field>
        <field name="groups" eval="[(4, ref('group_partes_profesor'))]"/>
    </record>

    <record id="gestion_faltas_parte_grupos_rule" model="ir.rule">
        <field name="name">Gestión de partes grupos</field>
        <field name="model_id" ref="model_gestion_faltas_parte"/>
        <field name="domain_force">[(1, '=',1)]</field>
        <field name="groups" eval="[(4, ref('group_partes_tutor'))]"/>
    </record>

    <record id="gestion_faltas_parte_todos_rule" model="ir.rule">
        <field name="name">Gestión de partes todos</field>
        <field name="model_id" ref="model_gestion_faltas_parte"/>
        <field name="domain_force">[(1,'=', 1)]</field>
        <field name="groups" eval="[(4, ref('group_partes_direccion'))]"/>
    </record>
</odoo>