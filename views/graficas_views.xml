<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="action_parte_graficas_trimestre" model="ir.actions.act_window">
        <field name="name">gestion_faltas.graficas_trimestre</field>
        <field name="res_model">gestion_faltas.parte</field>
        <field name="view_mode">graph</field>
        <field name="view_id" ref="view_parte_graph_trimestres"/>
    </record>

    <record id="view_parte_graph_trimestres" model="ir.ui.view">
        <field name="name">gestion_faltas.parte.graph.trimestres</field>
        <field name="model">gestion_faltas.parte</field>
        <field name="arch" type="xml">
            <graph string="Partes por Trimestres">
                <field name="fecha_hora" interval="month"/>
            </graph>
        </field>
    </record>


